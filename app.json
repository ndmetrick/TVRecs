{
	"expo": {
		"name": "TVRecs",
		"slug": "TVRecs",
		"version": "1.0.11",
		"orientation": "portrait",
		"icon": "./assets/images/splash-logo.png",
		"scheme": "tvrecs",
		"userInterfaceStyle": "automatic",
		"newArchEnabled": true,
		"ios": {
			"supportsTablet": true,
			"bundleIdentifier": "com.ndmetrick.tvrecs",
			"infoPlist": {
				"ITSAppUsesNonExemptEncryption": false
			}
		},
		"android": {
			"adaptiveIcon": {
				"foregroundImage": "./assets/images/android-icon-foreground.png",
				"backgroundColor": "#ffffff"
			},
			"edgeToEdgeEnabled": true,
			"predictiveBackGestureEnabled": false,
			"package": "com.ndmetrick.tvrecs",
			"versionCode": 11
		},
		"web": {
			"output": "static",
			"favicon": "./assets/images/tempTVRecsLogo.png"
		},
		"plugins": [
			"expo-router",
			[
				"expo-splash-screen",
				{
					"image": "./assets/images/splash-logo.png",
					"imageWidth": 200,
					"resizeMode": "contain",
					"backgroundColor": "#ffffff",
					"dark": {
						"backgroundColor": "#000000"
					}
				}
			],
			"@sentry/react-native"
		],
		"experiments": {
			"typedRoutes": true,
			"reactCompiler": true
		},
		"extra": {
			"router": {},
			"eas": {
				"projectId": "ef2bb273-1281-4d39-978b-8f50cdded4e1"
			}
		},
		"owner": "ndmetrick"
	}
}
